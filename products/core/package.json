{
  "name": "@iedora/product-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Core product — auth + admin guards consumed by apps/web's core.iedora.com routes (sign-in/up/out + sessions/audit). After Opt-B the Next.js routes themselves live in apps/web/src/app/core/; this package only exposes server-only guards (getSession, requireIedoraAdmin).",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@iedora/auth": "workspace:*",
    "@iedora/brand": "workspace:*",
    "@iedora/design-system": "workspace:*",
    "server-only": "^0.0.1"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "next-intl": "^4.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@iedora/eslint-config": "workspace:*",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.6",
    "eslint": "^9.39.4",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "^19.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.7"
  }
}
