# Menu dev template — copy to `.env.local`, fill in MENU_SESSION_SECRET,
# leave the Zitadel block empty. `bun run dev` boots Zitadel locally and
# writes the OIDC creds into `.env.development.local` (auto-loaded by
# Next, overrides `.env.local`).
#
# `.env.local` is gitignored; `.env.example` is the tracked source of truth.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menu

# Menu public URL — used to build the OIDC redirect_uri + CORS origin.
MENU_PUBLIC_URL=http://localhost:3000

# Menu session-cookie encryption key (jose, dir / A256GCM). >= 32 chars.
# Generate with: openssl rand -base64 48. In production this is minted by
# `random_password.menu_session_secret` (infra/tofu/zitadel.tf), so dev
# is the only place a human picks a value.
MENU_SESSION_SECRET=

# Zitadel OIDC client credentials — LEAVE BLANK in `.env.local`.
# `bun run dev` runs the local Zitadel (docker compose) + a one-shot
# `tofu apply` that creates the OIDC app and writes the resulting
# client_id / client_secret / management PAT into `.env.development.local`.
# Next loads that file automatically with higher precedence than
# `.env.local`, so the runtime gets the seeded values.
#
# If you really need to point at a different Zitadel (e.g. a shared
# staging instance), set these here and they'll win over the auto-seed.
ZITADEL_ISSUER_URL=
ZITADEL_OAUTH_CLIENT_ID=
ZITADEL_OAUTH_CLIENT_SECRET=
ZITADEL_MANAGEMENT_TOKEN=

# Object storage (S3-compatible: LocalStack local, R2/S3 in prod)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=menu

# OpenTelemetry / observability ----------------------------------------------
# OTLP HTTP endpoint that the @iedora/observability SDK ships spans to.
# Production points at `http://infra-openobserve:5080/api/default`. Leave
# blank in local dev unless you've started a collector — the SDK
# degrades to a "logs once at boot, never exports" mode when unset.
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTLP ingest auth — `Authorization=Basic%20<base64(email:password)>`.
OTEL_EXPORTER_OTLP_HEADERS=

# Git SHA — CI passes this at build time. Local dev: leave blank.
GIT_SHA=

# Per-host name. Becomes the `host.name` resource attribute. Local dev: blank.
HOST_NAME=
