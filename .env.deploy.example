# Deploy-only template — Tofu, Kamal, and box-side secrets.
# Copy to `.env.deploy` (gitignored), fill in every value.
#
# Critically: filename does NOT match Next.js's auto-load pattern
# (.env, .env.local, .env.<environment>) — so `bun run dev` never sees these
# values. If the Next app leaks `process.env`, infra creds stay safe.
#
# Loaded by the Makefile via `-include .env.deploy`.

# ── Cloudflare ───────────────────────────────────────────────────────────────
# Dashboard right sidebar + Profile → API Tokens.
# Token scopes:
#   - Account · Cloudflare Tunnel · Edit
#   - Zone · DNS · Edit (scoped to your zone)
#   - Account · Account Settings · Read
#   - Account · Workers R2 Storage · Edit
#   - User · API Tokens · Edit          (Tofu creates a sub-token for R2 dumps)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Public app hostname (must be a subdomain of your Cloudflare zone).
# Assets are served from `assets.<rest-of-hostname>` automatically.
PUBLIC_HOSTNAME=menu.example.com

# Homelab / cloud box. Kamal connects as root with SSH-key-only login.
ONPREM_HOST=192.168.50.53

# GitHub Container Registry — your GH username; image is pushed to
# ghcr.io/$GHCR_USER/meta-menu. Run `gh auth refresh -s write:packages` once.
GHCR_USER=

# ── Production app secrets (openssl rand -hex 32 each) ───────────────────────
# Kamal pushes these into the container env at deploy time via .kamal/secrets.
# Keep this file in your password manager — it holds everything needed to
# redeploy from scratch.

STATE_PASSPHRASE=                       # Tofu state encryption
BETTER_AUTH_SECRET=                     # signs prod Better Auth sessions
POSTGRES_PASSWORD=                      # prod postgres
MINIO_ROOT_PASSWORD=                    # prod MinIO + app's S3 secret
MINIO_ROOT_USER=metamenu

# ── Backups (R2 + Kamal `backups` accessory) ─────────────────────────────────
# The R2 bucket AND the S3 access keys are both provisioned by Tofu — the
# Cloudflare API token's ID + SHA-256(value) double as S3 credentials
# (see infra/tofu/outputs.tf). No manual dashboard step.
#
# The one value you generate yourself: BACKUP_PASSPHRASE — the GPG passphrase
# that encrypts each dump. KEEP THIS IN YOUR PASSWORD MANAGER. Lose it = lose
# the ability to decrypt past backups. Generate: `openssl rand -hex 32`.
BACKUP_PASSPHRASE=
