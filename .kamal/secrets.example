# Kamal destinations split secrets into:
#   .kamal/secrets-common      — values shared across destinations (this template)
#   .kamal/secrets.onprem      — onprem-specific overrides
#   .kamal/secrets.hetzner     — hetzner-specific overrides
#
# Copy to `.kamal/secrets-common` (gitignored) and fill in.
# Syntax is bash — `KEY=$(cmd)` or `KEY=value`. Sourced at deploy time.
#
# Quick generators:
#   BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#   POSTGRES_PASSWORD=$(openssl rand -hex 32)        # URL-safe hex
#   MINIO_ROOT_USER=metamenu                          # any alnum >= 3 chars
#   MINIO_ROOT_PASSWORD=$(openssl rand -hex 32)      # MinIO requires >= 8 chars
#
# Production-grade alternative (2026 best practice): replace plain values
# with `kamal secrets fetch` from 1Password / AWS Secrets Manager / etc.
# See: kamal-deploy.org/docs/commands/secrets/

# Registry (GHCR) — gh CLI logged in resolves the token on the fly.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# ── App ──────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=

# ── Postgres accessory ───────────────────────────────────────────────────────
# Password is embedded in DATABASE_URL — replace CHANGEME consistently.
POSTGRES_PASSWORD=
DATABASE_URL=postgres://postgres:CHANGEME@meta-menu-postgres:5432/metamenu
REDIS_URL=redis://meta-menu-redis:6379

# ── MinIO accessory + S3 SDK access ──────────────────────────────────────────
# MinIO root creds double as the S3 access keys the app uses (admin access
# to the bucket). MINIO_ROOT_USER = S3_ACCESS_KEY, MINIO_ROOT_PASSWORD = S3_SECRET_KEY.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ACCESS_KEY=$MINIO_ROOT_USER
S3_SECRET_KEY=$MINIO_ROOT_PASSWORD
