# Copia para `.kamal/secrets` (gitignored) e preenche os valores.
# Sintaxe Kamal: `KEY=$(comando)` ou `KEY=valor`.
#
# Exemplos:
#   KAMAL_REGISTRY_PASSWORD=$(gh auth token)     # GHCR via gh CLI
#   BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#   POSTGRES_PASSWORD=$(openssl rand -base64 24)

# Registry (GHCR)
KAMAL_REGISTRY_PASSWORD=

# App secrets
BETTER_AUTH_SECRET=
DATABASE_URL=postgres://postgres:CHANGEME@meta-menu-postgres:5432/metamenu
REDIS_URL=redis://meta-menu-redis:6379

# Postgres accessory
POSTGRES_PASSWORD=

# S3 / R2 — em local usar credenciais LocalStack ("test"); em prod credenciais R2 reais
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
