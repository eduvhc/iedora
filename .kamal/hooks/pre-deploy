#!/usr/bin/env bash
set -euo pipefail

# Pre-deploy hook: runs Drizzle migrations against the *new* image before
# any new container takes traffic. A failure aborts the deploy entirely
# (the old container keeps serving with the old schema).
#
# First-time deploy on a fresh server: do NOT use this hook —
# `make kamal-bootstrap` pre-boots the accessories and runs setup with
# --skip-hooks (basecamp/kamal#526).

# Rollback: old image, old schema is already correct.
if [[ "${KAMAL_COMMAND:-}" == "rollback" ]]; then
  echo "[pre-deploy] rollback detected, skipping migrations"
  exit 0
fi

# Without KAMAL_VERSION we can't target the new image.
if [[ -z "${KAMAL_VERSION:-}" ]]; then
  echo "[pre-deploy] no KAMAL_VERSION, skipping migrations"
  exit 0
fi

echo "[pre-deploy] running Drizzle migrations against ${KAMAL_VERSION}"

kamal app exec \
  --primary \
  --version="$KAMAL_VERSION" \
  "node scripts/migrate.mjs"
