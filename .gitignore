# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Vitest
.vitest-cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
/playwright/.auth/

# Claude Code — local user settings (skills are shared)
.claude/settings.local.json
.claude/

# Infra — artefactos locais não versionados
infra/**/*.iso
infra/**/.terraform/
infra/**/terraform.tfstate
infra/**/terraform.tfstate.backup
infra/**/terraform.tfstate.d/
infra/**/terraform.tfvars
!infra/**/terraform.tfvars.example
# Per-env tfvars for the workspaces pattern.
infra/**/envs/*.tfvars
!infra/**/envs/example.tfvars
# .terraform.lock.hcl SHOULD be committed — pins provider versions

# Kamal — secrets reais nunca vão para o repo (só o .example)
infra/**/.kamal/secrets
infra/**/.kamal/secrets-common
!infra/**/.kamal/secrets.example
